/* pages/sql/sql.wxss */

.container {
  min-height: 100vh;
  background: #0a1628;
  color: #fff;
  padding: 20rpx;
}

/* 顶部选择 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.school-picker {
  display: flex;
  align-items: center;
  background: #1a2a44;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
}

.school-picker .label {
  color: #8b9bb4;
  font-size: 28rpx;
}

.school-picker .value {
  color: #fff;
  font-size: 28rpx;
  margin: 0 10rpx;
}

.school-picker .arrow {
  color: #8b9bb4;
  font-size: 24rpx;
}

.history-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #1a2a44;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.history-btn .icon {
  font-size: 32rpx;
}

/* 历史记录面板 */
.history-panel {
  background: #1a2a44;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  max-height: 400rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #2a3a54;
}

.clear-btn {
  color: #ff6b6b;
  font-size: 26rpx;
}

.history-list {
  max-height: 300rpx;
}

.history-item {
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #2a3a54;
}

.history-sql {
  font-size: 26rpx;
  color: #e0e0e0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.history-meta {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8b9bb4;
}

/* SQL编辑器 */
.sql-editor {
  background: #1a2a44;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.editor-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.editor-header text:first-child {
  font-size: 30rpx;
  font-weight: bold;
}

.hint {
  color: #ff6b6b;
  font-size: 24rpx;
}

.sql-input {
  width: 100%;
  min-height: 200rpx;
  background: #0a1628;
  border-radius: 8rpx;
  padding: 16rpx;
  color: #00ff00;
  font-family: 'Courier New', monospace;
  font-size: 28rpx;
  line-height: 1.6;
}

.editor-actions {
  margin-top: 20rpx;
}

.btn-primary {
  width: 100%;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 32rpx;
}

.btn-primary[disabled] {
  background: #4a5a6a;
  color: #8b9bb4;
}

/* 错误面板 - 详细版 */
.error-panel {
  background: #2a1a1a;
  border: 1px solid rgba(255, 77, 79, 0.3);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.error-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
  color: #ff6b6b;
  font-size: 30rpx;
  font-weight: 500;
}

.error-content {
  color: #e0e0e0;
  font-size: 26rpx;
  word-break: break-all;
  margin-bottom: 16rpx;
}

.error-suggestion {
  font-size: 24rpx;
  color: #faad14;
  background: rgba(250, 173, 20, 0.1);
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.error-type {
  font-size: 22rpx;
  color: #8b9bb4;
  margin-top: 8rpx;
}

/* 查询结果面板 */
.results-panel {
  background: #1a2a44;
  border-radius: 12rpx;
  padding: 20rpx;
}

.results-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.stats {
  display: flex;
  gap: 20rpx;
}

.count {
  color: #1890ff;
  font-size: 28rpx;
  font-weight: 500;
}

.time {
  color: #8b9bb4;
  font-size: 28rpx;
}

.actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  color: #1890ff;
  font-size: 26rpx;
  padding: 8rpx 16rpx;
  background: rgba(24, 144, 255, 0.1);
  border-radius: 8rpx;
}

.action-btn.primary {
  background: linear-gradient(135deg, #52c41a, #73d13d);
  color: #fff;
}

/* 查询统计 */
.query-stats {
  display: flex;
  justify-content: space-around;
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #1890ff;
}

.stat-label {
  font-size: 22rpx;
  color: #8b9bb4;
  margin-top: 6rpx;
}

/* 滚动提示 */
.scroll-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx;
  background: rgba(24, 144, 255, 0.05);
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.scroll-hint text {
  font-size: 22rpx;
  color: rgba(24, 144, 255, 0.8);
}

/* 结果表格 - 支持横向滚动 */
.results-table {
  width: 100%;
  background: #0a1628;
  border-radius: 12rpx;
  overflow: hidden;
}

.table-scroll {
  width: 100%;
  white-space: nowrap;
}

.table-wrapper {
  display: inline-table;
  min-width: 100%;
}

.table-header {
  display: flex;
  background: rgba(24, 144, 255, 0.15);
  position: sticky;
  top: 0;
  z-index: 10;
}

.th {
  flex-shrink: 0;
  min-width: 160rpx;
  max-width: 300rpx;
  padding: 20rpx 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #1890ff;
  text-align: center;
  border-right: 1rpx solid rgba(255, 255, 255, 0.05);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.th:last-child {
  border-right: none;
}

.table-body {
  max-height: 500rpx;
  overflow-y: auto;
}

.tr {
  display: flex;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.tr:last-child {
  border-bottom: none;
}

.tr:nth-child(even) {
  background: rgba(255, 255, 255, 0.02);
}

.td {
  flex-shrink: 0;
  min-width: 160rpx;
  max-width: 300rpx;
  padding: 16rpx;
  font-size: 24rpx;
  color: #e0e0e0;
  text-align: center;
  border-right: 1rpx solid rgba(255, 255, 255, 0.03);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.td:last-child {
  border-right: none;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 40rpx;
  color: #8b9bb4;
  font-size: 28rpx;
}

/* 提示信息 */
.tips {
  background: #1a2a44;
  border-radius: 12rpx;
  padding: 24rpx;
}

.tip-title {
  font-size: 30rpx;
  margin-bottom: 16rpx;
  color: #ffc107;
}

.tip-item {
  color: #8b9bb4;
  font-size: 26rpx;
  line-height: 1.8;
}
