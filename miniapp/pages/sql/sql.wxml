<!-- pages/sql/sql.wxml -->
<view class="container">
  <!-- 顶部选择 -->
  <view class="header">
    <picker mode="selector" range="{{schools}}" range-key="name" bindchange="onSchoolChange">
      <view class="school-picker">
        <text class="label">学校：</text>
        <text class="value">{{selectedSchool.name || '请选择学校'}}</text>
        <text class="arrow">▼</text>
      </view>
    </picker>
    
    <view class="history-btn" bindtap="toggleHistory">
      <text class="icon">📋</text>
      <text>历史</text>
    </view>
  </view>

  <!-- 历史记录浮层 -->
  <view class="history-panel" wx:if="{{showHistory}}">
    <view class="history-header">
      <text>SQL历史</text>
      <text class="clear-btn" bindtap="clearHistory">清空</text>
    </view>
    <scroll-view scroll-y class="history-list">
      <view class="history-item" wx:for="{{history}}" wx:key="sql" bindtap="useHistory" data-sql="{{item.sql}}">
        <view class="history-sql">{{item.sql}}</view>
        <view class="history-meta">
          <text>{{item.school}}</text>
          <text>{{item.time}}</text>
        </view>
      </view>
      <view class="empty" wx:if="{{!history.length}}">
        暂无历史记录
      </view>
    </scroll-view>
  </view>

  <!-- SQL编辑器 -->
  <view class="sql-editor">
    <view class="editor-header">
      <text>SQL语句</text>
      <text class="hint">仅支持SELECT查询</text>
    </view>
    <textarea 
      class="sql-input" 
      placeholder="请输入SELECT查询语句..."
      value="{{sqlContent}}"
      bindinput="onSqlInput"
      auto-height
      maxlength="-1"
    ></textarea>
    
    <view class="editor-actions">
      <button class="btn-primary" bindtap="executeSql" loading="{{loading}}" disabled="{{loading}}">
        执行查询
      </button>
    </view>
  </view>

  <!-- 错误提示 -->
  <view class="error-panel" wx:if="{{error}}">
    <view class="error-header">
      <text class="icon">❌</text>
      <text>查询失败</text>
    </view>
    <view class="error-content">{{error}}</view>
  </view>

  <!-- 查询结果 -->
  <view class="results-panel" wx:if="{{results}}">
    <view class="results-header">
      <view class="stats">
        <text class="count">共 {{results.count}} 条</text>
        <text class="time">耗时 {{results.queryTime}}ms</text>
      </view>
      <view class="actions">
        <text class="action-btn" bindtap="copySql">复制SQL</text>
        <text class="action-btn" bindtap="exportResults">导出Excel</text>
        <text class="action-btn" bindtap="clearResults">清空</text>
      </view>
    </view>
    
    <!-- 结果表格 -->
    <scroll-view scroll-x scroll-y class="results-table">
      <view class="table-wrapper">
        <view class="table-header">
          <view class="th" wx:for="{{results.rows[0]}}" wx:for-index="key" wx:for-item="value" wx:key="key">
            {{key}}
          </view>
        </view>
        <view class="table-body">
          <view class="tr" wx:for="{{results.rows}}" wx:for-index="rowIdx" wx:key="rowIdx">
            <view class="td" wx:for="{{item}}" wx:for-index="key" wx:for-item="value" wx:key="key">
              {{value || '-'}}
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
    
    <view class="empty" wx:if="{{!results.rows.length}}">
      查询结果为空
    </view>
  </view>

  <!-- 提示信息 -->
  <view class="tips" wx:if="{{!results && !error}}">
    <view class="tip-title">💡 使用提示</view>
    <view class="tip-item">1. 仅支持 SELECT 查询语句</view>
    <view class="tip-item">2. 禁止 DROP、DELETE、UPDATE、INSERT 等修改操作</view>
    <view class="tip-item">3. 查询结果最多显示 1000 条</view>
    <view class="tip-item">4. 可点击"历史"查看之前的查询</view>
  </view>
</view>
