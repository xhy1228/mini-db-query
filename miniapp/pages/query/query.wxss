/* pages/query/query.wxss */

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 页面头部 */
.page-header {
  margin-bottom: 30rpx;
  padding: 20rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.school-name {
  font-size: 28rpx;
  color: #1890ff;
  background: rgba(24, 144, 255, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
}

.school-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 区块样式 */
.section {
  margin-bottom: 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.back-btn {
  margin-right: 16rpx;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
}

.back-btn text {
  font-size: 28rpx;
  color: #1890ff;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

/* 业务大类列表 */
.category-list, .template-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.category-card, .template-card {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  transition: all 0.3s ease;
}

.category-card:active, .template-card:active {
  transform: scale(0.98);
}

.category-main {
  display: flex;
  align-items: center;
  flex: 1;
}

.category-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.category-info, .template-info {
  display: flex;
  flex-direction: column;
}

.category-name, .template-name {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.category-count, .template-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.category-arrow, .template-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* 模板字段标签 */
.template-fields {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.field-tag {
  font-size: 20rpx;
  color: #1890ff;
  background: rgba(24, 144, 255, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  border: 1px solid rgba(24, 144, 255, 0.3);
}

/* 查询表单 */
.query-form {
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.form-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 24rpx;
}

.form-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 20rpx;
}

.form-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  width: 140rpx;
}

.form-operator {
  font-size: 24rpx;
  color: #1890ff;
  background: rgba(24, 144, 255, 0.15);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #fff;
}

.placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.form-divider {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.1);
  margin: 24rpx 0;
}

.form-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 20rpx;
  display: block;
}

/* 时间选择 */
.time-row {
  display: flex;
  gap: 20rpx;
}

.time-item {
  flex: 1;
}

.time-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  display: block;
  margin-bottom: 10rpx;
}

.time-picker {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
}

.time-picker.has-value {
  color: #fff;
  border-color: rgba(24, 144, 255, 0.3);
}

/* 查询按钮 */
.query-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  border-radius: 48rpx;
  border: none;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 32rpx rgba(24, 144, 255, 0.4);
}

.query-btn[disabled] {
  opacity: 0.7;
}

/* 查询结果 */
.result-section {
  margin-top: 30rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.result-count {
  font-size: 24rpx;
  color: #1890ff;
  background: rgba(24, 144, 255, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

/* 结果表格 */
.result-table {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  overflow: hidden;
}

.table-scroll {
  width: 100%;
}

.table {
  min-width: 100%;
}

.table-header {
  display: flex;
  background: rgba(24, 144, 255, 0.1);
}

.th {
  flex-shrink: 0;
  min-width: 150rpx;
  padding: 20rpx 16rpx;
  font-size: 24rpx;
  color: #1890ff;
  font-weight: 500;
  text-align: center;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.table-body {
  max-height: 500rpx;
  overflow-y: auto;
}

.tr {
  display: flex;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.tr:last-child {
  border-bottom: none;
}

.td {
  flex-shrink: 0;
  min-width: 150rpx;
  padding: 16rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 空状态 */
.empty-state, .result-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 快捷时间选择 */
.quick-time-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.quick-time-item {
  flex: 1;
  padding: 16rpx 0;
  text-align: center;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  transition: all 0.3s;
}

.quick-time-item.active {
  background: rgba(24, 144, 255, 0.2);
  border-color: #1890ff;
  color: #1890ff;
}

/* 结果操作按钮 */
.result-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.export-btn {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #52c41a, #73d13d);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #fff;
}
