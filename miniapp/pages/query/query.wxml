<!-- pages/query/query.wxml -->
<view class="container">
  
  <!-- 顶部装饰 -->
  <view class="header-decoration">
    <view class="decoration-circle circle-1"></view>
    <view class="decoration-circle circle-2"></view>
    <view class="decoration-line"></view>
  </view>

  <!-- 数据库选择 -->
  <view class="section config-section">
    <view class="section-header">
      <view class="section-icon">
        <text class="icon">🗄️</text>
      </view>
      <text class="section-title">选择数据库</text>
    </view>
    <picker 
      mode="selector" 
      range="{{configs}}" 
      range-key="name"
      bindchange="onConfigChange"
    >
      <view class="picker-box tech-card">
        <text class="picker-text">{{selectedConfig || '请选择数据库'}}</text>
        <text class="picker-arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- 查询模式切换 -->
  <view class="section mode-section">
    <view class="mode-tabs">
      <view 
        class="mode-tab {{queryMode === 'smart' ? 'active' : ''}}" 
        bindtap="switchMode" 
        data-mode="smart"
      >
        <text class="mode-icon">🧠</text>
        <text>智能查询</text>
      </view>
      <view 
        class="mode-tab {{queryMode === 'sql' ? 'active' : ''}}" 
        bindtap="switchMode" 
        data-mode="sql"
      >
        <text class="mode-icon">📝</text>
        <text>SQL查询</text>
      </view>
    </view>
  </view>

  <!-- 智能查询面板 -->
  <view class="section smart-panel" wx:if="{{queryMode === 'smart'}}">
    <view class="panel-header">
      <text class="panel-title">查询条件</text>
      <text class="panel-hint">支持多条件组合</text>
    </view>
    
    <!-- 业务大类 -->
    <view class="form-item">
      <text class="form-label">业务大类</text>
      <picker 
        mode="selector" 
        range="{{categories}}" 
        range-key="name"
        bindchange="onCategoryChange"
      >
        <view class="input-box tech-card">
          <text>{{selectedCategoryName || '请选择业务大类'}}</text>
        </view>
      </picker>
    </view>

    <!-- 业务类型 -->
    <view class="form-item" wx:if="{{queries.length > 0}}">
      <text class="form-label">查询类型</text>
      <picker 
        mode="selector" 
        range="{{queries}}" 
        range-key="name"
        bindchange="onQueryChange"
      >
        <view class="input-box tech-card">
          <text>{{selectedQueryName || '请选择查询类型'}}</text>
        </view>
      </picker>
    </view>

    <!-- 查询条件 -->
    <view class="form-item" wx:if="{{fields.length > 0}}">
      <text class="form-label">查询条件</text>
      <view class="condition-row">
        <picker 
          mode="selector" 
          range="{{fields}}" 
          range-key="label"
          bindchange="onFieldChange"
        >
          <view class="condition-picker">
            <text>{{selectedFieldLabel || '选择字段'}}</text>
          </view>
        </picker>
        <picker 
          mode="selector" 
          range="{{operators}}" 
          bindchange="onOperatorChange"
        >
          <view class="operator-picker">
            <text>{{selectedOperator || '='}}</text>
          </view>
        </picker>
        <input 
          class="value-input" 
          placeholder="输入查询值" 
          placeholder-class="placeholder"
          bindinput="onValueInput"
          value="{{queryValue}}"
        />
      </view>
    </view>

    <!-- 时间范围 -->
    <view class="form-item">
      <view class="time-toggle" bindtap="toggleTimeRange">
        <text class="toggle-label">⏰ 时间范围</text>
        <view class="toggle-switch {{enableTimeRange ? 'on' : ''}}">
          <view class="toggle-dot"></view>
        </view>
      </view>
      <view class="time-pickers" wx:if="{{enableTimeRange}}">
        <view class="time-input-box tech-card">
          <text class="time-label">从</text>
          <picker mode="date" bindchange="onStartTimeChange">
            <text class="time-value">{{startTime || '开始时间'}}</text>
          </picker>
        </view>
        <view class="time-input-box tech-card">
          <text class="time-label">至</text>
          <picker mode="date" bindchange="onEndTimeChange">
            <text class="time-value">{{endTime || '结束时间'}}</text>
          </picker>
        </view>
      </view>
    </view>
  </view>

  <!-- SQL查询面板 -->
  <view class="section sql-panel" wx:if="{{queryMode === 'sql'}}">
    <view class="panel-header">
      <text class="panel-title">SQL语句</text>
      <text class="panel-hint">直接输入SQL</text>
    </view>
    <textarea 
      class="sql-input tech-card" 
      placeholder="SELECT * FROM table_name WHERE ..."
      placeholder-class="placeholder"
      bindinput="onSqlInput"
      value="{{sqlText}}"
      maxlength="-1"
    ></textarea>
    <view class="sql-hint">
      <text>⚠️ 仅支持SELECT查询，不支持增删改</text>
    </view>
  </view>

  <!-- 查询按钮 -->
  <view class="query-btn-area">
    <button 
      class="query-btn btn-primary" 
      bindtap="executeQuery"
      loading="{{loading}}"
    >
      <text wx:if="{{!loading}}">🔍 开始查询</text>
      <text wx:else>查询中...</text>
    </button>
  </view>

  <!-- 结果展示 -->
  <view class="section result-section" wx:if="{{result.length > 0}}">
    <view class="result-header">
      <text class="result-title">查询结果</text>
      <text class="result-count">{{result.length}} 条记录</text>
    </view>
    
    <scroll-view class="result-scroll" scroll-x>
      <view class="result-table">
        <!-- 表头 -->
        <view class="table-header">
          <view 
            class="table-th" 
            wx:for="{{resultHeaders}}" 
            wx:key="index"
            style="width: {{100 / resultHeaders.length}}%"
          >
            {{item}}
          </view>
        </view>
        <!-- 表体 -->
        <view class="table-body">
          <view 
            class="table-tr" 
            wx:for="{{result}}" 
            wx:for-item="row"
            wx:key="index"
          >
            <view 
              class="table-td" 
              wx:for="{{resultHeaders}}" 
              wx:for-item="header"
              wx:key="header"
              style="width: {{100 / resultHeaders.length}}%"
            >
              {{row[header] || '-'}}
            </view>
          </view>
        </view>
      </view>
    </scroll-view>

    <!-- 导出按钮 -->
    <view class="export-area">
      <button class="export-btn" bindtap="exportResult">
        <text>📥 导出Excel</text>
      </button>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!result.length && queried}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">未查询到数据</text>
  </view>

</view>
