/* pages/history/history.wxss */

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 头部装饰 */
.header-decoration {
  position: relative;
  height: 60rpx;
  margin-bottom: 20rpx;
}

.decoration-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.6;
}

.circle-1 {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  top: 10rpx;
  left: 20rpx;
  animation: pulse 2s infinite;
}

.circle-2 {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #40a9ff, #69c0ff);
  top: 0;
  right: 100rpx;
  animation: pulse 2s infinite 0.5s;
}

/* 页面标题 */
.page-header {
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 历史列表 */
.history-list {
  margin-top: 20rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 16rpx;
  transition: all 0.3s ease;
}

.history-item:active {
  transform: scale(0.98);
  opacity: 0.8;
}

.history-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, rgba(24, 144, 255, 0.2), rgba(24, 144, 255, 0.1));
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  border: 1px solid rgba(24, 144, 255, 0.3);
}

.history-icon text {
  font-size: 36rpx;
}

.history-content {
  flex: 1;
  min-width: 0;
}

.history-title {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.history-sql {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 12rpx;
  font-family: 'Courier New', monospace;
}

.history-meta {
  display: flex;
  gap: 16rpx;
}

.meta-time, .meta-count, .meta-db {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  background: rgba(255, 255, 255, 0.05);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.history-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 160rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* 清空按钮 */
.clear-area {
  position: fixed;
  bottom: 60rpx;
  left: 40rpx;
  right: 40rpx;
}

.clear-btn {
  width: 100%;
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.6);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  padding: 24rpx;
  font-size: 28rpx;
}
