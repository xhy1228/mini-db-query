<!-- pages/index/index.wxml -->
<view class="container">

  <!-- 顶部背景 -->
  <view class="header-bg">
    <view class="bg-circle bg-circle-1"></view>
    <view class="bg-circle bg-circle-2"></view>
  </view>

  <!-- 用户信息 -->
  <view class="user-section" wx:if="{{userInfo}}">
    <view class="user-card glass-card">
      <view class="user-avatar">
        <text>👤</text>
      </view>
      <view class="user-info">
        <text class="user-name">{{userInfo.name || '用户'}}</text>
        <text class="user-role">{{isAdmin ? '管理员' : '普通用户'}}</text>
      </view>
      <view class="user-badge" wx:if="{{isAdmin}}">
        <text>超级管理员</text>
      </view>
    </view>
  </view>

  <!-- 今日统计 -->
  <view class="section stats-section" wx:if="{{stats}}">
    <view class="stats-grid">
      <view class="stat-item glass-card">
        <text class="stat-value">{{stats.today_queries || 0}}</text>
        <text class="stat-label">今日查询</text>
      </view>
      <view class="stat-item glass-card">
        <text class="stat-value">{{stats.total_queries || 0}}</text>
        <text class="stat-label">总查询数</text>
      </view>
      <view class="stat-item glass-card">
        <text class="stat-value">{{stats.success_rate || 0}}%</text>
        <text class="stat-label">成功率</text>
      </view>
      <view class="stat-item glass-card">
        <text class="stat-value">{{stats.active_users || 0}}</text>
        <text class="stat-label">活跃用户</text>
      </view>
    </view>
  </view>

  <!-- 查询历史入口 -->
  <view class="section recent-section">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">🕐</text>
        <text>查询历史</text>
      </view>
    </view>
    <view class="history-entry glass-card" bindtap="goToHistory">
      <view class="entry-icon">📋</view>
      <view class="entry-info">
        <text class="entry-title">查看查询历史</text>
        <text class="entry-desc">查看历史查询记录和数据</text>
      </view>
      <view class="entry-arrow">›</view>
    </view>
  </view>

  <!-- 学校选择 -->
  <view class="section school-section">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">🏫</text>
        <text>选择学校</text>
      </view>
    </view>

    <!-- 学校列表 -->
    <view class="school-list" wx:if="{{!loading && schools.length > 0}}">
      <view 
        class="school-card tech-card {{selectedSchool.id === item.id ? 'selected' : ''}}" 
        wx:for="{{schools}}" 
        wx:key="id"
        data-school="{{item}}"
        bindtap="onSchoolTap"
      >
        <view class="school-icon">
          <text>🏛️</text>
        </view>
        <view class="school-info">
          <text class="school-name">{{item.name}}</text>
          <text class="school-code">{{item.code}}</text>
        </view>
        <view class="school-check" wx:if="{{selectedSchool.id === item.id}}">
          <text>✓</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && schools.length === 0}}">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无授权学校</text>
      <text class="empty-hint">请联系管理员分配学校权限</text>
    </view>
  </view>

  <!-- 业务大类 -->
  <view class="section category-section" wx:if="{{selectedSchool}}">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">📂</text>
        <text>{{selectedSchool.name}} - 业务大类</text>
      </view>
    </view>

    <!-- 业务大类列表 -->
    <view class="category-list" wx:if="{{categories.length > 0}}">
      <view 
        class="category-card tech-card" 
        wx:for="{{categories}}" 
        wx:key="id"
        data-category="{{item}}"
        bindtap="onCategoryTap"
      >
        <view class="category-main">
          <text class="category-icon">{{item.icon}}</text>
          <view class="category-info">
            <text class="category-name">{{item.name}}</text>
            <text class="category-count">{{item.count}}个查询</text>
          </view>
        </view>
        <view class="category-arrow">›</view>
      </view>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="section quick-section">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">⚡</text>
        <text>快捷入口</text>
      </view>
    </view>
    <view class="quick-grid">
      <view class="quick-item glass-card" bindtap="goToQuery">
        <view class="quick-icon" style="background: rgba(24, 144, 255, 0.2); border-color: rgba(24, 144, 255, 0.5);">
          <text>🔍</text>
        </view>
        <text class="quick-name">开始查询</text>
      </view>
      <view class="quick-item glass-card" bindtap="goToQuery">
        <view class="quick-icon" style="background: rgba(82, 196, 26, 0.2); border-color: rgba(82, 196, 26, 0.5);">
          <text>📋</text>
        </view>
        <text class="quick-name">查询历史</text>
      </view>
      <view class="quick-item glass-card" bindtap="goToQuery">
        <view class="quick-icon" style="background: rgba(250, 173, 20, 0.2); border-color: rgba(250, 173, 20, 0.5);">
          <text>📥</text>
        </view>
        <text class="quick-name">导出记录</text>
      </view>
      <view class="quick-item glass-card" bindtap="goToQuery">
        <view class="quick-icon" style="background: rgba(114, 46, 209, 0.2); border-color: rgba(114, 46, 209, 0.5);">
          <text>⚙️</text>
        </view>
        <text class="quick-name">设置</text>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content glass-card">
      <view class="loading-spinner"></view>
      <text>加载中...</text>
    </view>
  </view>

</view>
