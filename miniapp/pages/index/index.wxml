<!-- pages/index/index.wxml -->
<view class="container">

  <!-- 顶部背景 -->
  <view class="header-bg">
    <view class="bg-circle bg-circle-1"></view>
    <view class="bg-circle bg-circle-2"></view>
  </view>

  <!-- 用户信息 -->
  <view class="user-section" wx:if="{{userInfo}}">
    <view class="user-card glass-card">
      <view class="user-avatar">
        <text>👤</text>
      </view>
      <view class="user-info">
        <text class="user-name">{{userInfo.name || '用户'}}</text>
        <text class="user-role">{{isAdmin ? '管理员' : '普通用户'}}</text>
      </view>
      <view class="user-badge" wx:if="{{isAdmin}}">
        <text>超级管理员</text>
      </view>
    </view>
  </view>

  <!-- 今日统计 -->
  <view class="section stats-section" wx:if="{{stats}}">
    <view class="stats-grid">
      <view class="stat-item glass-card">
        <text class="stat-value">{{stats.today_queries || 0}}</text>
        <text class="stat-label">今日查询</text>
      </view>
      <view class="stat-item glass-card">
        <text class="stat-value">{{stats.total_queries || 0}}</text>
        <text class="stat-label">总查询数</text>
      </view>
      <view class="stat-item glass-card">
        <text class="stat-value">{{stats.success_rate || 0}}%</text>
        <text class="stat-label">成功率</text>
      </view>
      <view class="stat-item glass-card">
        <text class="stat-value">{{stats.active_users || 0}}</text>
        <text class="stat-label">活跃用户</text>
      </view>
    </view>
  </view>

  <!-- 最近查询 -->
  <view class="section recent-section" wx:if="{{recentQueries.length > 0}}">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">🕐</text>
        <text>最近查询</text>
      </view>
      <view class="section-more" bindtap="goToHistory">
        <text>查看全部</text>
        <text>›</text>
      </view>
    </view>
    <view class="recent-list">
      <view class="recent-item glass-card" wx:for="{{recentQueries}}" wx:key="id">
        <view class="recent-info">
          <text class="recent-name">{{item.query_name || '查询'}}</text>
          <text class="recent-time">{{item.timeText}}</text>
        </view>
        <view class="recent-meta">
          <text class="recent-count">{{item.result_count || 0}}条</text>
          <text class="recent-status {{item.status === 'success' ? 'success' : 'failed'}}">
            {{item.status === 'success' ? '成功' : '失败'}}
          </text>
        </view>
      </view>
    </view>
  </view>

  <!-- 学校选择（入口形式） -->
  <view class="section school-section">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">🏫</text>
        <text>选择学校</text>
      </view>
    </view>

    <!-- 学校选择入口 -->
    <view class="school-entry glass-card" bindtap="showSchoolPicker">
      <view class="school-entry-icon">
        <text>🏛️</text>
      </view>
      <view class="school-entry-info">
        <text class="school-entry-name">{{selectedSchool.name || '请选择学校'}}</text>
        <text class="school-entry-hint">点击切换学校</text>
      </view>
      <view class="school-entry-arrow">▼</view>
    </view>

    <!-- 学校选择弹窗 -->
    <view class="school-picker-mask" wx:if="{{showSchoolPicker}}" bindtap="hideSchoolPicker">
      <view class="school-picker glass-card" catchtap="">
        <view class="picker-header">
          <text class="picker-title">选择学校</text>
          <view class="picker-close" bindtap="hideSchoolPicker">✕</view>
        </view>
        <view class="picker-list">
          <view 
            class="picker-item {{selectedSchool.id === item.id ? 'selected' : ''}}" 
            wx:for="{{schools}}" 
            wx:key="id"
            data-school="{{item}}"
            bindtap="onSchoolSelect"
          >
            <text class="picker-item-name">{{item.name}}</text>
            <text class="picker-item-check" wx:if="{{selectedSchool.id === item.id}}">✓</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && schools.length === 0}}">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无授权学校</text>
      <text class="empty-hint">请联系管理员分配学校权限</text>
    </view>
  </view>

  <!-- 业务大类（下拉选择） -->
  <view class="section category-section" wx:if="{{selectedSchool}}">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">📂</text>
        <text>业务大类</text>
      </view>
    </view>

    <!-- 业务大类选择入口 -->
    <view class="category-entry glass-card" bindtap="showCategoryPicker">
      <view class="category-entry-icon">
        <text>{{selectedCategory.category_icon || '📋'}}</text>
      </view>
      <view class="category-entry-info">
        <text class="category-entry-name">{{selectedCategory.category_name || '请选择业务大类'}}</text>
        <text class="category-entry-count">共 {{categories.length}} 个大类</text>
      </view>
      <view class="category-entry-arrow">▼</view>
    </view>

    <!-- 业务大类选择弹窗 -->
    <view class="category-picker-mask" wx:if="{{showCategoryPicker}}" bindtap="hideCategoryPicker">
      <view class="category-picker glass-card" catchtap="">
        <view class="picker-header">
          <text class="picker-title">选择业务大类</text>
          <view class="picker-close" bindtap="hideCategoryPicker">✕</view>
        </view>
        <view class="picker-list">
          <view 
            class="picker-item {{selectedCategory.category === item.category ? 'selected' : ''}}" 
            wx:for="{{categories}}" 
            wx:key="category"
            data-category="{{item}}"
            bindtap="onCategorySelect"
          >
            <text class="picker-item-icon">{{item.category_icon}}</text>
            <text class="picker-item-name">{{item.category_name}}</text>
            <text class="picker-item-count">{{item.functions.length}}个功能</text>
            <text class="picker-item-check" wx:if="{{selectedCategory.category === item.category}}">✓</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 开始查询按钮 -->
    <view class="start-query-btn" wx:if="{{selectedCategory}}" bindtap="startQuery">
      <text>开始查询</text>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="section quick-section">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">⚡</text>
        <text>快捷入口</text>
      </view>
    </view>
    <view class="quick-grid">
      <view class="quick-item glass-card" bindtap="goToQuery">
        <view class="quick-icon" style="background: rgba(24, 144, 255, 0.2); border-color: rgba(24, 144, 255, 0.5);">
          <text>🔍</text>
        </view>
        <text class="quick-name">开始查询</text>
      </view>
      <view class="quick-item glass-card" bindtap="goToHistory">
        <view class="quick-icon" style="background: rgba(82, 196, 26, 0.2); border-color: rgba(82, 196, 26, 0.5);">
          <text>📋</text>
        </view>
        <text class="quick-name">查询历史</text>
      </view>
      <view class="quick-item glass-card" bindtap="goToProfile">
        <view class="quick-icon" style="background: rgba(114, 46, 209, 0.2); border-color: rgba(114, 46, 209, 0.5);">
          <text>👤</text>
        </view>
        <text class="quick-name">我的</text>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content glass-card">
      <view class="loading-spinner"></view>
      <text>加载中...</text>
    </view>
  </view>

</view>
