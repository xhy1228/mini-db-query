/* pages/index/index.wxss */

.container {
  padding: 20rpx;
  min-height: 100vh;
  position: relative;
  overflow-x: hidden;
}

/* 顶部背景装饰 */
.header-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  overflow: hidden;
  z-index: 0;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.15;
  filter: blur(40rpx);
}

.bg-circle-1 {
  width: 400rpx;
  height: 400rpx;
  background: #1890ff;
  top: -100rpx;
  left: -100rpx;
  animation: float 8s ease-in-out infinite;
}

.bg-circle-2 {
  width: 300rpx;
  height: 300rpx;
  background: #40a9ff;
  top: 50rpx;
  right: -50rpx;
  animation: float 10s ease-in-out infinite 2s;
}

.bg-circle-3 {
  width: 200rpx;
  height: 200rpx;
  background: #69c0ff;
  top: 200rpx;
  left: 50%;
  animation: float 6s ease-in-out infinite 4s;
}

.bg-line {
  position: absolute;
  width: 100%;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(24, 144, 255, 0.3), transparent);
  top: 300rpx;
}

@keyframes float {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-30rpx) scale(1.05); }
}

/* 头部区域 */
.header {
  position: relative;
  z-index: 1;
  padding: 40rpx 0;
  margin-bottom: 20rpx;
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.logo-area {
  display: flex;
  align-items: center;
}

.logo-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(24, 144, 255, 0.4);
  animation: pulse 3s infinite;
}

.logo-icon text {
  font-size: 40rpx;
}

.logo-text {
  display: flex;
  flex-direction: column;
}

.logo-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 2rpx;
}

.logo-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
}

.version-badge {
  background: linear-gradient(135deg, rgba(24, 144, 255, 0.2), rgba(24, 144, 255, 0.1));
  border: 1px solid rgba(24, 144, 255, 0.3);
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  color: #1890ff;
}

/* 区块样式 */
.section {
  position: relative;
  z-index: 1;
  margin-bottom: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.section-title {
  display: flex;
  align-items: center;
}

.title-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

.section-title text:last-child {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.section-more {
  font-size: 24rpx;
  color: #1890ff;
}

/* 快捷入口 */
.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  transition: all 0.3s ease;
}

.quick-item:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.quick-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  border: 1px solid;
  transition: all 0.3s ease;
}

.quick-icon text {
  font-size: 36rpx;
}

.quick-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 业务大类列表 */
.category-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.category-card {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  transition: all 0.3s ease;
}

.category-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.category-main {
  display: flex;
  align-items: center;
  flex: 1;
}

.category-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.category-info {
  display: flex;
  flex-direction: column;
}

.category-name {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.category-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.category-stats {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
}

.stats-number {
  font-size: 36rpx;
  font-weight: 600;
  color: #1890ff;
}

.stats-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

.category-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* 数据库配置列表 */
.config-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.config-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  transition: all 0.3s ease;
}

.config-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.config-icon {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, rgba(24, 144, 255, 0.2), rgba(24, 144, 255, 0.1));
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  border: 1px solid rgba(24, 144, 255, 0.3);
}

.config-icon text {
  font-size: 32rpx;
}

.config-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.config-name {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.config-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.config-status {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
}

.config-status.online {
  background: rgba(82, 196, 26, 0.15);
  color: #52c41a;
  border: 1px solid rgba(82, 196, 26, 0.3);
}

.config-status.offline {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
}

.loading-state text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 20rpx;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* 系统信息 */
.system-info {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 40rpx;
  margin-top: 20rpx;
}

.system-info text {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  margin-bottom: 6rpx;
}
