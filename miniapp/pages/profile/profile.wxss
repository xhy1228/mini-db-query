/* pages/profile/profile.wxss */

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 顶部背景 */
.header-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  overflow: hidden;
  z-index: 0;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.15;
}

.bg-circle-1 {
  width: 400rpx;
  height: 400rpx;
  background: #1890ff;
  top: -100rpx;
  right: -100rpx;
}

.bg-circle-2 {
  width: 300rpx;
  height: 300rpx;
  background: #40a9ff;
  bottom: -50rpx;
  left: -50rpx;
}

/* 用户卡片 */
.user-card {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 40rpx;
  margin-bottom: 20rpx;
}

.avatar-container {
  margin-right: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(24, 144, 255, 0.4);
}

.avatar text {
  font-size: 60rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.user-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-phone {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.user-role-tag {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  background: rgba(255, 255, 255, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.user-role-tag.admin {
  color: #1890ff;
  background: rgba(24, 144, 255, 0.15);
}

/* 统计卡片 */
.stats-card {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stats-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.1);
  margin: 0 40rpx;
}

/* 快捷操作 */
.quick-actions {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-around;
  flex-wrap: wrap;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
  margin-bottom: 20rpx;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, rgba(24, 144, 255, 0.2), rgba(24, 144, 255, 0.1));
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  border: 1px solid rgba(24, 144, 255, 0.3);
}

.action-icon text {
  font-size: 36rpx;
}

.action-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 菜单列表 */
.menu-section {
  position: relative;
  z-index: 1;
  margin-bottom: 20rpx;
  padding: 10rpx 0;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: rgba(255, 255, 255, 0.05);
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.9);
}

.menu-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* 版本信息 */
.version-info {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 60rpx 40rpx;
}

.version-info text {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.3);
  margin-bottom: 8rpx;
}

/* 权限卡片 */
.permission-card {
  position: relative;
  z-index: 1;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.card-header {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

.permission-section {
  margin-bottom: 24rpx;
}

.permission-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 16rpx;
}

.school-list, .template-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.school-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.school-name {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.permission-tags {
  display: flex;
  gap: 12rpx;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

.tag-query {
  background: rgba(24, 144, 255, 0.2);
  color: #40a9ff;
}

.tag-export {
  background: rgba(82, 196, 26, 0.2);
  color: #52c41a;
}

.template-item {
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.template-name {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 8rpx;
}

.template-category {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 12rpx;
}

.permission-icons {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
}

.icon-yes {
  color: #52c41a;
}

.icon-no {
  color: rgba(255, 255, 255, 0.3);
}
