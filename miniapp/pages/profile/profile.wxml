<!-- pages/profile/profile.wxml -->
<view class="container">
  
  <!-- 顶部装饰 -->
  <view class="header-decoration">
    <view class="decoration-circle circle-1"></view>
    <view class="decoration-circle circle-2"></view>
    <view class="decoration-circle circle-3"></view>
  </view>

  <!-- 用户信息卡片 -->
  <view class="user-card tech-card">
    <view class="avatar-container">
      <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="avatar-glow"></view>
    </view>
    <view class="user-info">
      <text class="username">{{userInfo.nickname || '用户'}}</text>
      <text class="user-role">{{userInfo.role === 'admin' ? '管理员' : '普通用户'}}</text>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="quick-actions">
    <view class="action-item" bindtap="onQuickAction" data-action="history">
      <view class="action-icon">
        <text>📋</text>
      </view>
      <text class="action-label">查询历史</text>
    </view>
    <view class="action-item" bindtap="onQuickAction" data-action="favorites">
      <view class="action-icon">
        <text>⭐</text>
      </view>
      <text class="action-label">收藏查询</text>
    </view>
    <view class="action-item" bindtap="onQuickAction" data-action="export">
      <view class="action-icon">
        <text>📥</text>
      </view>
      <text class="action-label">导出记录</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <view class="menu-title">功能设置</view>
    
    <view class="menu-list">
      <view class="menu-item" bindtap="onMenuTap" data-menu="configs">
        <view class="menu-left">
          <text class="menu-icon">🗄️</text>
          <text class="menu-text">数据库配置</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-item" bindtap="onMenuTap" data-menu="templates">
        <view class="menu-left">
          <text class="menu-icon">📋</text>
          <text class="menu-text">查询模板</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-item" bindtap="onMenuTap" data-menu="about">
        <view class="menu-left">
          <text class="menu-icon">ℹ️</text>
          <text class="menu-text">关于</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 关于信息 -->
  <view class="about-section">
    <view class="app-info">
      <text class="app-name">多源数据查询</text>
      <text class="app-version">小程序版 v1.0.0</text>
    </view>
    <view class="copyright">
      <text>Powered by 飞书百万</text>
    </view>
  </view>

</view>
