# Mini DB Query Configuration
# Configure database via web interface: http://localhost:26316/setup

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=26316
DEBUG=True

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET_KEY=mini-db-query-secret-key-2026
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ============================================
# WeChat Mini Program (Optional)
# ============================================
WECHAT_APPID=
WECHAT_SECRET=

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_DIR=./logs

# ============================================
# Security Configuration
# ============================================
ALLOWED_ORIGINS=*
MAX_QUERY_ROWS=10000
QUERY_TIMEOUT=30

# ============================================
# Database Configuration
# Set via /setup page
# ============================================
DATABASE_URL=
