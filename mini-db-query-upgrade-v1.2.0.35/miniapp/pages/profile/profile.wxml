<!-- pages/profile/profile.wxml -->
<view class="container">

  <!-- 顶部装饰 -->
  <view class="header-bg">
    <view class="bg-circle bg-circle-1"></view>
    <view class="bg-circle bg-circle-2"></view>
  </view>

  <!-- 用户卡片 -->
  <view class="user-card glass-card">
    <view class="avatar-container">
      <view class="avatar">
        <text>👤</text>
      </view>
    </view>
    <view class="user-info">
      <text class="username">{{userInfo.name || '用户'}}</text>
      <view class="user-meta">
        <text class="user-phone">{{userInfo.phone || '未设置'}}</text>
        <text class="user-role-tag {{isAdmin ? 'admin' : ''}}">
          {{isAdmin ? '管理员' : '普通用户'}}
        </text>
      </view>
    </view>
  </view>

  <!-- 统计数据（可点击查看详情） -->
  <view class="stats-card glass-card" wx:if="{{userInfo}}">
    <view class="stats-item" bindtap="showSchoolList">
      <text class="stats-value">{{stats.queryCount}}</text>
      <text class="stats-label">查询次数</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item clickable" bindtap="showSchoolList">
      <text class="stats-value">{{stats.schoolCount}}</text>
      <text class="stats-label">可查询学校</text>
      <text class="stats-arrow">›</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item clickable" bindtap="showTemplateList">
      <text class="stats-value">{{stats.templateCount}}</text>
      <text class="stats-label">可查询模板</text>
      <text class="stats-arrow">›</text>
    </view>
  </view>

  <!-- 学校详情弹窗 -->
  <view class="detail-modal-mask" wx:if="{{showSchoolModal}}" bindtap="hideSchoolModal">
    <view class="detail-modal glass-card" catchtap="">
      <view class="modal-header">
        <text class="modal-title">可查询学校 ({{schools.length}})</text>
        <view class="modal-close" bindtap="hideSchoolModal">✕</view>
      </view>
      <view class="modal-list">
        <view class="modal-item" wx:for="{{schools}}" wx:key="id">
          <text class="modal-item-icon">🏛️</text>
          <view class="modal-item-info">
            <text class="modal-item-name">{{item.name}}</text>
            <text class="modal-item-code">{{item.code || ''}}</text>
          </view>
        </view>
        <view class="modal-empty" wx:if="{{schools.length === 0}}">
          <text>暂无授权学校</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 模板详情弹窗 -->
  <view class="detail-modal-mask" wx:if="{{showTemplateModal}}" bindtap="hideTemplateModal">
    <view class="detail-modal glass-card" catchtap="">
      <view class="modal-header">
        <text class="modal-title">可查询模板 ({{templateList.length}})</text>
        <view class="modal-close" bindtap="hideTemplateModal">✕</view>
      </view>
      <view class="modal-list">
        <view class="modal-item" wx:for="{{templateList}}" wx:key="id">
          <text class="modal-item-icon">📋</text>
          <view class="modal-item-info">
            <text class="modal-item-name">{{item.name}}</text>
            <text class="modal-item-desc">{{item.category_name || ''}}</text>
          </view>
        </view>
        <view class="modal-empty" wx:if="{{templateList.length === 0}}">
          <text>暂无可查询模板</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 权限信息 -->
  <view class="permission-card glass-card" wx:if="{{!isAdmin && schools.length > 0}}">
    <view class="card-header">
      <text class="card-title">我的权限</text>
    </view>
    
    <!-- 学校权限 -->
    <view class="permission-section">
      <view class="section-title">学校权限</view>
      <view class="school-list">
        <view class="school-item" wx:for="{{schools}}" wx:key="id">
          <view class="school-name">{{item.name}}</view>
          <view class="permission-tags">
            <text class="tag tag-query" wx:if="{{item.permissions && item.permissions.includes('query')}}">查询</text>
            <text class="tag tag-export" wx:if="{{item.permissions && item.permissions.includes('export')}}">导出</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 模板权限 -->
    <view class="permission-section" wx:if="{{templatePermissions.length > 0}}">
      <view class="section-title">模板权限（{{templatePermissions.length}}个）</view>
      <view class="template-list">
        <view class="template-item" wx:for="{{templatePermissions}}" wx:key="template_id">
          <view class="template-name">{{item.template_name}}</view>
          <view class="template-category">{{item.category}}</view>
          <view class="permission-icons">
            <text class="icon-yes" wx:if="{{item.can_query}}">✓ 查询</text>
            <text class="icon-no" wx:else>✗ 查询</text>
            <text class="icon-yes" wx:if="{{item.can_export}}">✓ 导出</text>
            <text class="icon-no" wx:else>✗ 导出</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="quick-actions glass-card">
    <view class="action-item" data-action="history" bindtap="onQuickAction">
      <view class="action-icon">
        <text>📋</text>
      </view>
      <text class="action-label">查询历史</text>
    </view>
    <view class="action-item" data-action="query" bindtap="onQuickAction">
      <view class="action-icon">
        <text>🔍</text>
      </view>
      <text class="action-label">开始查询</text>
    </view>
    <!-- 管理员专属功能 -->
    <view class="action-item" data-action="sql" bindtap="onQuickAction" wx:if="{{isAdmin}}">
      <view class="action-icon">
        <text>💻</text>
      </view>
      <text class="action-label">SQL查询</text>
    </view>
    <view class="action-item" data-action="admin" bindtap="onQuickAction" wx:if="{{isAdmin}}">
      <view class="action-icon">
        <text>⚙️</text>
      </view>
      <text class="action-label">管理后台</text>
    </view>
    <view class="action-item" data-action="about" bindtap="onQuickAction">
      <view class="action-icon">
        <text>ℹ️</text>
      </view>
      <text class="action-label">关于</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section glass-card">
    <view class="menu-item" data-menu="about" bindtap="onMenuTap">
      <view class="menu-left">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于我们</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    
    <view class="menu-item" bindtap="copyServerUrl">
      <view class="menu-left">
        <text class="menu-icon">🔗</text>
        <text class="menu-text">服务器地址</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    
    <!-- 数据管理 -->
    <view class="menu-item" bindtap="clearMyData">
      <view class="menu-left">
        <text class="menu-icon">🗑️</text>
        <text class="menu-text">清除我的数据</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    
    <!-- 账号注销 -->
    <view class="menu-item" bindtap="deleteMyAccount">
      <view class="menu-left">
        <text class="menu-icon">⚠️</text>
        <text class="menu-text" style="color: #ff4d4f;">注销账号</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    
    <view class="menu-item" data-menu="logout" bindtap="onMenuTap">
      <view class="menu-left">
        <text class="menu-icon">🚪</text>
        <text class="menu-text" style="color: #ff4d4f;">退出登录</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>多源数据查询小程序 v{{version}}</text>
    <text>Powered by FastAPI</text>
  </view>

</view>
