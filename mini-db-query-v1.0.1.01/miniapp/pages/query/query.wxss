/* pages/query/query.wxss */

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 页面头部 */
.page-header {
  margin-bottom: 30rpx;
  padding: 20rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.school-name {
  font-size: 28rpx;
  color: #1890ff;
  background: rgba(24, 144, 255, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
}

.school-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 区块样式 */
.section {
  margin-bottom: 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.back-btn {
  margin-right: 16rpx;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
}

.back-btn text {
  font-size: 28rpx;
  color: #1890ff;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

/* 业务大类列表 */
.category-list, .template-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.category-card, .template-card {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  transition: all 0.3s ease;
}

.category-card:active, .template-card:active {
  transform: scale(0.98);
}

.category-main {
  display: flex;
  align-items: center;
  flex: 1;
}

.category-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.category-info, .template-info {
  display: flex;
  flex-direction: column;
}

.category-name, .template-name {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.category-count, .template-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.category-arrow, .template-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* 模板字段标签 */
.template-fields {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.field-tag {
  font-size: 20rpx;
  color: #1890ff;
  background: rgba(24, 144, 255, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  border: 1px solid rgba(24, 144, 255, 0.3);
}

/* 查询表单 */
.query-form {
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.form-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 24rpx;
}

.form-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 20rpx;
}

.form-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  width: 140rpx;
}

.form-operator {
  font-size: 24rpx;
  color: #1890ff;
  background: rgba(24, 144, 255, 0.15);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #fff;
}

.placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.form-divider {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.1);
  margin: 24rpx 0;
}

.form-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 20rpx;
  display: block;
}

/* 时间选择 */
.time-row {
  display: flex;
  gap: 20rpx;
}

.time-item {
  flex: 1;
}

.time-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  display: block;
  margin-bottom: 10rpx;
}

.time-picker {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
}

.time-picker.has-value {
  color: #fff;
  border-color: rgba(24, 144, 255, 0.3);
}

/* 查询按钮 */
.query-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  border-radius: 48rpx;
  border: none;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 32rpx rgba(24, 144, 255, 0.4);
}

.query-btn[disabled] {
  opacity: 0.7;
}

/* 查询结果 */
.result-section {
  margin-top: 30rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.result-count {
  font-size: 24rpx;
  color: #1890ff;
  background: rgba(24, 144, 255, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

/* 结果操作按钮 */
.result-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.export-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #52c41a, #73d13d);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #fff;
}

.export-btn:active {
  opacity: 0.8;
}

/* 结果表格容器 - 支持横向滚动 */
.result-table {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  overflow: hidden;
}

/* 横向滚动提示 */
.scroll-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx;
  background: rgba(24, 144, 255, 0.05);
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.scroll-hint text {
  font-size: 22rpx;
  color: rgba(24, 144, 255, 0.8);
}

/* 横向滚动区域 */
.table-scroll {
  width: 100%;
  white-space: nowrap;
}

/* 表格 */
.table {
  display: inline-table;
  min-width: 100%;
  border-collapse: collapse;
}

/* 表头 */
.table-header {
  display: flex;
  background: rgba(24, 144, 255, 0.15);
  position: sticky;
  top: 0;
  z-index: 10;
}

.th {
  flex-shrink: 0;
  min-width: 160rpx;
  max-width: 300rpx;
  padding: 24rpx 16rpx;
  font-size: 24rpx;
  color: #1890ff;
  font-weight: 600;
  text-align: center;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  border-right: 1px solid rgba(255, 255, 255, 0.05);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.th:last-child {
  border-right: none;
}

/* 表体 */
.table-body {
  max-height: 600rpx;
  overflow-y: auto;
}

.tr {
  display: flex;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  transition: background 0.2s;
}

.tr:active {
  background: rgba(24, 144, 255, 0.05);
}

.tr:last-child {
  border-bottom: none;
}

.td {
  flex-shrink: 0;
  min-width: 160rpx;
  max-width: 300rpx;
  padding: 20rpx 16rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  border-right: 1px solid rgba(255, 255, 255, 0.03);
}

.td:last-child {
  border-right: none;
}

/* 长文本单元格 */
.td-long {
  white-space: normal;
  word-break: break-all;
  line-height: 1.4;
}

/* 斑马纹 */
.tr:nth-child(even) {
  background: rgba(255, 255, 255, 0.02);
}

/* 空状态 */
.empty-state, .result-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 快捷时间选择 */
.quick-time-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.quick-time-item {
  flex: 1;
  padding: 16rpx 0;
  text-align: center;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  transition: all 0.3s;
}

.quick-time-item.active {
  background: rgba(24, 144, 255, 0.2);
  border-color: #1890ff;
  color: #1890ff;
}

/* 查询信息统计 */
.query-info {
  display: flex;
  justify-content: space-around;
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.info-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #1890ff;
}

.info-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 6rpx;
}

/* 导出选项弹窗 */
.export-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.export-dialog {
  width: 80%;
  max-width: 600rpx;
  background: #1a1a2e;
  border-radius: 24rpx;
  padding: 40rpx;
}

.export-dialog-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  text-align: center;
  margin-bottom: 30rpx;
}

.export-option {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.export-option:active {
  background: rgba(24, 144, 255, 0.1);
}

.export-option-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.export-option-text {
  flex: 1;
}

.export-option-title {
  font-size: 28rpx;
  color: #fff;
  margin-bottom: 4rpx;
}

.export-option-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.export-cancel {
  text-align: center;
  padding: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 28rpx;
}

/* SQL预览 */
.sql-preview {
  background: rgba(0, 0, 0, 0.3);
  border-radius: 12rpx;
  padding: 16rpx;
  margin-top: 16rpx;
}

.sql-text {
  font-size: 22rpx;
  color: #52c41a;
  font-family: monospace;
  word-break: break-all;
}

/* 错误信息显示 */
.error-box {
  background: rgba(255, 77, 79, 0.1);
  border: 1px solid rgba(255, 77, 79, 0.3);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 16rpx;
}

.error-title {
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.error-message {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 12rpx;
  word-break: break-all;
}

.error-suggestion {
  font-size: 24rpx;
  color: #faad14;
  background: rgba(250, 173, 20, 0.1);
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
}

/* 数据详情弹窗 */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.detail-panel {
  width: 100%;
  max-height: 80vh;
  background: #1a1a2e;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.detail-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.detail-close {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.5);
  padding: 0 20rpx;
}

.detail-content {
  padding: 20rpx 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.detail-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.detail-label {
  width: 200rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
}

.detail-value {
  flex: 1;
  font-size: 26rpx;
  color: #fff;
  word-break: break-all;
}
