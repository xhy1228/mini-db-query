/* app.wxss - 全局样式 */

/* 主题色 */
page {
  --primary: #1890ff;
  --primary-light: #40a9ff;
  --primary-dark: #096dd9;
  --success: #52c41a;
  --warning: #faad14;
  --error: #f5222d;
  --bg-dark: #0a1628;
  --bg-card: rgba(255, 255, 255, 0.08);
  --text-primary: #ffffff;
  --text-secondary: rgba(255, 255, 255, 0.65);
  --border-color: rgba(255, 255, 255, 0.1);
  
  background: linear-gradient(135deg, #0a1628 0%, #1a2a4a 50%, #0d1b2a 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 科技感卡片 */
.tech-card {
  background: linear-gradient(145deg, rgba(24, 144, 255, 0.1) 0%, rgba(10, 22, 40, 0.8) 100%);
  border: 1px solid rgba(24, 144, 255, 0.3);
  border-radius: 16rpx;
  backdrop-filter: blur(10px);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), 
              inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
}

/* 玻璃态效果 */
.glass-card {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
}

/* 发光边框 */
.glow-border {
  border: 1px solid rgba(24, 144, 255, 0.5);
  box-shadow: 0 0 20rpx rgba(24, 144, 255, 0.3),
              inset 0 0 20rpx rgba(24, 144, 255, 0.1);
}

/* 渐变按钮 */
.btn-primary {
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  color: #fff;
  border-radius: 50rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.4);
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.4);
}

/* 发光文字 */
.glow-text {
  text-shadow: 0 0 10rpx rgba(24, 144, 255, 0.8),
               0 0 20rpx rgba(24, 144, 255, 0.5);
}

/* 渐变文字 */
.gradient-text {
  background: linear-gradient(90deg, #1890ff, #40a9ff, #69c0ff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 动画效果 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

@keyframes glow {
  0%, 100% { box-shadow: 0 0 20rpx rgba(24, 144, 255, 0.3); }
  50% { box-shadow: 0 0 40rpx rgba(24, 144, 255, 0.6); }
}

.animate-fade-in {
  animation: fadeIn 0.5s ease-out;
}

.animate-pulse {
  animation: pulse 2s infinite;
}

.animate-glow {
  animation: glow 2s infinite;
}

/* 图标容器 */
.icon-container {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(24, 144, 255, 0.2) 0%, rgba(24, 144, 255, 0.05) 100%);
  border: 1px solid rgba(24, 144, 255, 0.3);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(24, 144, 255, 0.3), transparent);
  margin: 32rpx 0;
}

/* 加载动画 */
.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(24, 144, 255, 0.2);
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
