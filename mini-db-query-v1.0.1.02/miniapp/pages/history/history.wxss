/* pages/history/history.wxss */

.container {
  min-height: 100vh;
  background: #0a1628;
  color: #fff;
  padding: 20rpx;
}

/* 顶部操作栏 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 16rpx;
  background: #1a2a44;
  border-radius: 8rpx;
}

.filter-btn, .clear-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #1890ff;
}

.filter-btn .icon, .clear-btn .icon {
  font-size: 32rpx;
}

.total {
  font-size: 28rpx;
  color: #8b9bb4;
}

/* 筛选面板 */
.filter-panel {
  background: #1a2a44;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #2a3a54;
}

.filter-item:last-of-type {
  border-bottom: none;
}

.filter-item .label {
  font-size: 28rpx;
  color: #8b9bb4;
}

.picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #fff;
}

.picker .arrow {
  font-size: 20rpx;
  color: #8b9bb4;
}

.filter-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.filter-actions button {
  flex: 1;
  font-size: 28rpx;
}

/* 历史列表 */
.history-list {
  
}

.history-item {
  background: #1a2a44;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-left: 6rpx solid transparent;
}

.history-item.success {
  border-left-color: #52c41a;
}

.history-item.failed {
  border-left-color: #ff4d4f;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.query-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.status-badge {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.status-badge.success {
  background: rgba(82, 196, 26, 0.2);
  color: #52c41a;
}

.status-badge.failed {
  background: rgba(255, 77, 79, 0.2);
  color: #ff4d4f;
}

.item-body {
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  margin-bottom: 8rpx;
  font-size: 26rpx;
}

.info-row .label {
  color: #8b9bb4;
  width: 100rpx;
}

.info-row .value {
  color: #e0e0e0;
}

.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #8b9bb4;
}

.detail-hint {
  color: #1890ff;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  color: #8b9bb4;
  font-size: 28rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty .icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty .text {
  color: #8b9bb4;
  font-size: 28rpx;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
  color: #8b9bb4;
  font-size: 28rpx;
}
