/* pages/history-detail/history-detail.wxss */

.container {
  min-height: 100vh;
  background: #0a1628;
  color: #fff;
  padding: 20rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: #8b9bb4;
}

/* 状态卡片 */
.status-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.status-card.success {
  background: linear-gradient(135deg, #1a4a1a 0%, #0a2a0a 100%);
}

.status-card.failed {
  background: linear-gradient(135deg, #4a1a1a 0%, #2a0a0a 100%);
}

.status-icon {
  font-size: 60rpx;
  margin-right: 20rpx;
}

.status-text {
  flex: 1;
}

.status-text .title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.status-text .name {
  display: block;
  font-size: 28rpx;
  color: #8b9bb4;
}

/* 信息区块 */
.info-section {
  background: #1a2a44;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

.copy-btn {
  color: #1890ff;
  font-size: 26rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #2a3a54;
}

.info-item:last-child {
  border-bottom: none;
}

.info-item .label {
  color: #8b9bb4;
  font-size: 28rpx;
}

.info-item .value {
  color: #fff;
  font-size: 28rpx;
}

/* SQL内容 */
.sql-content {
  background: #0a1628;
  border-radius: 8rpx;
  padding: 16rpx;
  font-family: 'Courier New', monospace;
  font-size: 26rpx;
  color: #00ff00;
  word-break: break-all;
  white-space: pre-wrap;
}

/* 参数内容 */
.params-content {
  background: #0a1628;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 26rpx;
  color: #e0e0e0;
  word-break: break-all;
  white-space: pre-wrap;
}

/* 错误区块 */
.error-section {
  background: #2a1a1a;
}

.error-content {
  background: #1a0a0a;
  border-radius: 8rpx;
  padding: 16rpx;
  color: #ff6b6b;
  font-size: 26rpx;
  word-break: break-all;
}

/* 操作按钮 */
.action-buttons {
  margin-top: 40rpx;
}

.btn-primary {
  width: 100%;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 32rpx;
  margin-bottom: 20rpx;
}

.btn-danger {
  width: 100%;
  background: transparent;
  color: #ff6b6b;
  border: 1rpx solid #ff6b6b;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 32rpx;
}

/* 空状态 */
.empty {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: #8b9bb4;
  font-size: 28rpx;
}
