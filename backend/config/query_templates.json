{
  "categories": {
    "student": {
      "name": "学生业务",
      "icon": "🎓",
      "description": "学生信息相关查询",
      "queries": {
        "student_info": {
          "name": "学生信息查询",
          "description": "查询学生基本信息",
          "db_config": "ccard_oracle",
          "table": "CARD_CUSTOMERS",
          "fields": [
            {"id": "name", "label": "姓名", "column": "CUSTNAME", "type": "text", "operator": "LIKE"},
            {"id": "student_id", "label": "学号", "column": "STUDENTID", "type": "text", "operator": "="},
            {"id": "id_card", "label": "身份证号", "column": "IDCARD", "type": "text", "operator": "="}
          ],
          "select_columns": ["CUSTNAME as 姓名", "STUDENTID as 学号", "IDCARD as 身份证号", "CARDID as 卡号", "CARDSTATE as 卡状态"],
          "time_field": null,
          "default_limit": 100
        }
      }
    },
    "consume": {
      "name": "消费业务",
      "icon": "💰",
      "description": "消费记录相关查询",
      "queries": {
        "consume_detail": {
          "name": "消费明细查询",
          "description": "查询消费流水明细",
          "db_config": "ccard_oracle",
          "table": "DATA_CARD_CONSUME",
          "fields": [
            {"id": "card_id", "label": "卡号", "column": "CARDID", "type": "text", "operator": "="},
            {"id": "student_id", "label": "学号", "column": "STUDENTID", "type": "text", "operator": "="}
          ],
          "select_columns": ["CARDID as 卡号", "STUDENTID as 学号", "TRANAMT as 交易金额", "TRATIME as 交易时间", "SHOPNAME as 商户名称"],
          "time_field": "TRATIME",
          "default_limit": 500
        },
        "recharge_detail": {
          "name": "充值明细查询",
          "description": "查询充值流水明细",
          "db_config": "ccard_oracle",
          "table": "DATA_ONLINE_CASH",
          "fields": [
            {"id": "card_id", "label": "卡号", "column": "CARDID", "type": "text", "operator": "="},
            {"id": "student_id", "label": "学号", "column": "STUDENTID", "type": "text", "operator": "="}
          ],
          "select_columns": ["CARDID as 卡号", "TRANAMT as 充值金额", "TRATIME as 充值时间", "PAYTYPE as 支付方式"],
          "time_field": "TRATIME",
          "default_limit": 500
        }
      }
    },
    "access": {
      "name": "门禁业务",
      "icon": "🚪",
      "description": "门禁记录相关查询",
      "queries": {
        "access_record": {
          "name": "进出门记录查询",
          "description": "查询门禁进出记录",
          "db_config": "ccard_oracle",
          "table": "ACCESS_INOUT_RECORD",
          "fields": [
            {"id": "card_id", "label": "卡号", "column": "CARDID", "type": "text", "operator": "="},
            {"id": "student_id", "label": "学号", "column": "STUDENTID", "type": "text", "operator": "="}
          ],
          "select_columns": ["CARDID as 卡号", "INOUTTIME as 进出时间", "INOUTFLAG as 进出标识", "DEVICENAME as 设备名称"],
          "time_field": "INOUTTIME",
          "default_limit": 500
        }
      }
    },
    "wechat": {
      "name": "微信业务",
      "icon": "💬",
      "description": "微信相关查询",
      "queries": {
        "wechat_user": {
          "name": "微信绑定查询",
          "description": "查询微信用户绑定信息",
          "db_config": "wechat_mysql",
          "table": "wx_user",
          "fields": [
            {"id": "nickname", "label": "昵称", "column": "nickname", "type": "text", "operator": "LIKE"},
            {"id": "phone", "label": "手机号", "column": "phone", "type": "text", "operator": "="}
          ],
          "select_columns": ["nickname as 昵称", "phone as 手机号", "create_time as 绑定时间", "status as 状态"],
          "time_field": "create_time",
          "default_limit": 100
        },
        "wechat_door_record": {
          "name": "微信门禁进出记录",
          "description": "查询微信门禁进出记录（sign_type: 0=进, 1=出）",
          "db_config": "wechat_mysql",
          "custom_sql": true,
          "custom_sql_template": "SELECT id, user_no AS '学号', CASE sign_type WHEN 0 THEN '进' WHEN 1 THEN '出' END AS '进出类型', device_name AS '设备名称', record_time AS '进出时间' FROM m_user_door_record_info WHERE user_no = '{value}' ORDER BY record_time DESC LIMIT 500",
          "fields": [
            {"id": "user_no", "label": "学号", "type": "text"}
          ],
          "default_limit": 500
        },
        "wechat_student_full": {
          "name": "微信学生完整信息",
          "description": "查询学生完整信息（含住宿、班主任）",
          "db_config": "wechat_mysql",
          "custom_sql": true,
          "custom_sql_template": "SELECT u.name AS '姓名', u.id_card AS '身份证号', u.user_number AS '学号', d.dept_name AS '班级', tu.name AS '班主任', CASE WHEN rb.id IS NOT NULL THEN '已入住' ELSE '未入住' END AS '住宿状态', a1.name AS '楼栋', a2.name AS '楼层', r.room_name AS '房间号', rb.bed_name AS '床位号' FROM sys_user u LEFT JOIN sys_dept d ON u.dept_id = d.dept_id LEFT JOIN sys_user_dept sud ON d.dept_id = sud.dept_id AND sud.header_teacher = 1 LEFT JOIN sys_user tu ON sud.user_id = tu.user_id LEFT JOIN wx_room_bed rb ON rb.user_id = u.user_id LEFT JOIN wx_room r ON rb.room_id = r.room_id LEFT JOIN wx_address a1 ON r.address_parent_id = a1.id LEFT JOIN wx_address a2 ON r.address_id = a2.id WHERE u.user_number = '{value}' OR u.name = '{value}' OR u.id_card = '{value}'",
          "fields": [
            {"id": "user_number", "label": "学号/姓名/身份证", "type": "text"}
          ],
          "default_limit": 100
        },
        "wechat_teacher": {
          "name": "班主任查询",
          "description": "查询所有班主任信息",
          "db_config": "wechat_mysql",
          "custom_sql": true,
          "custom_sql_template": "SELECT u.user_id, u.name AS '姓名', u.user_number AS '工号', d.dept_name AS '班级名称' FROM sys_user_dept ud JOIN sys_user u ON ud.user_id = u.user_id JOIN sys_dept d ON ud.dept_id = d.dept_id WHERE ud.header_teacher = 1",
          "fields": [],
          "default_limit": 500
        }
      }
    }
  }
}
