# Mini DB Query - 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# ============================================
# 服务配置
# ============================================
HOST=0.0.0.0
PORT=26316
DEBUG=True

# ============================================
# JWT配置
# ============================================
JWT_SECRET_KEY=mini-db-query-secret-key-2026
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ============================================
# 微信小程序配置 (可选)
# ============================================
WECHAT_APPID=
WECHAT_SECRET=

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO
LOG_DIR=./logs

# ============================================
# 查询配置
# ============================================
ALLOWED_ORIGINS=*
MAX_QUERY_ROWS=10000
QUERY_TIMEOUT=30

# ============================================
# 数据库配置
# 部署后通过 Web 界面 (/setup) 配置
# 此处留空，不要预填
# ============================================
DATABASE_URL=
