# 环境配置示例
# 请复制此文件为 .env 并填写实际值

# 应用配置
APP_NAME=多源数据查询小程序版
APP_VERSION=1.0.0
DEBUG=True

# 服务配置
HOST=0.0.0.0
PORT=8000

# 微信小程序配置
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret

# JWT配置
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# 数据库配置（可选，优先使用databases.yaml）
DATABASE_URL=

# Redis配置（可选）
REDIS_URL=redis://localhost:6379/0

# 文件上传配置
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads

# CORS配置
ALLOWED_ORIGINS=["*"]
