# ============================================
# 多源数据查询小程序版 - 环境变量配置
# ============================================

# 数据库配置
# SQLite (开发环境)
# DATABASE_URL=sqlite:///./data/mini_db_query.db

# MySQL (生产环境)
DATABASE_URL=mysql+pymysql://mini_query:your_password@localhost:3306/mini_db_query?charset=utf8mb4

# 微信小程序配置
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret

# JWT配置
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_EXPIRE_MINUTES=10080

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Redis配置 (可选)
# REDIS_URL=redis://localhost:6379/0

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# 查询配置
QUERY_TIMEOUT=30
MAX_EXPORT_ROWS=10000
